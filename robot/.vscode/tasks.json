{
    // ============================================================
    // Tasks VSCode pour le projet robot PMX-CORTEX
    //
    // Raccourci : Ctrl+Shift+T → menu de toutes les tasks
    // Barre de statut : boutons Deploy+Run, SSH, Recup SVG
    //   (extension actboy168.tasks)
    //
    // Chaque task ARM demande :
    //   1. L'IP de la carte (eth0, 5g, wifi, home)
    //   2. Le binaire a deployer (driver-test, common-test, etc.)
    //
    // Prerequis : sshpass (sudo apt install sshpass)
    // ============================================================
    "version": "2.0.0",
    "inputs": [
        {
            // carte1   = WiFi 5GHz AP     192.168.3.103
            // carte2   = WiFi 5GHz AP     192.168.3.104
            // carte3   = WiFi 5GHz AP     192.168.3.105
            // eth0  = cable RJ45 maison      192.168.0.44
            "id": "targetIP",
            "type": "pickString",
            "description": "Interface reseau OPOS6UL",
            "options": [
                { "label": "Carte 1 - WiFi 5G", "value": "192.168.3.103" },
                { "label": "Carte 2 - WiFi 5G", "value": "192.168.3.104" },
                { "label": "Carte 3 - WiFi 5G", "value": "192.168.3.105" },
                { "label": "Carte 2 - eth0", "value": "192.168.0.44" }
            ],
            "default": "192.168.3.103"
        },
        {
            "id": "buildPreset",
            "type": "pickString",
            "description": "Preset CMake a builder",
            "options": [
                { "label": "SIMU Debug",    "value": "simu-debug" },
                { "label": "SIMU Release",  "value": "simu-release" },
                { "label": "ARM Debug",     "value": "arm-debug" },
                { "label": "ARM Release",   "value": "arm-release" }
            ],
            "default": "simu-debug"
        },
        {
            "id": "targetBin",
            "type": "pickString",
            "description": "Binaire a deployer",
            "options": [
                "driver-test",
                "common-test",
                "manual-test",
                "bench",
                "bot-opos6ul"
            ],
            "default": "bot-opos6ul"
        }
    ],
    "tasks": [
        {
            // Build un preset au choix
            "label": "Build ALL",
            "type": "shell",
            "command": "cmake --preset ${input:buildPreset} && cmake --build --preset ${input:buildPreset} -j$(nproc)",
            "options": {
                "cwd": "${workspaceFolder}",
                "statusbar": {
                    "hide": false,
                    "label": "$(tools) BuildAll",
                    "color": "#61AFEF"
                }
            },
            "group": "build",
            "problemMatcher": "$gcc",
            "presentation": { "reveal": "always", "panel": "shared", "focus": true }
        },
        {
            // Build ARM + strip + scp (sans execution)
            "label": "ARM: Deploy",
            "type": "shell",
            "command": "bash sh/deploy.sh ${input:targetIP} ${input:targetBin} && echo '🤖 Bip Positronik, Successful transmission, captain Cho !'",
            "options": {
                "cwd": "${workspaceFolder}",
                "statusbar": {
                    "hide": false,
                    "label": "$(cloud-upload) Deploy",
                    "color": "#4EC9B0"
                }
            },
            "group": "build",
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared", "focus": true }
        },
        {
            // Build + strip + scp + kill ancien process + execute
            "label": "ARM: Deploy + Run",
            "type": "shell",
            "command": "bash sh/deploy.sh ${input:targetIP} ${input:targetBin} run && echo '🤖 Bip Positronik, Successful transmission, captain Cho !'",
            "options": {
                "cwd": "${workspaceFolder}",
                "statusbar": {
                    "hide": false,
                    "label": "$(rocket) Deploy+Run",
                    "color": "#4EC9B0"
                }
            },
            "group": "test",
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared", "focus": true }
        },
        {
            // Terminal SSH interactif dans /root/pmx/
            "label": "ARM: Connect SSH",
            "type": "shell",
            "command": "sshpass -p pmx ssh -t -o StrictHostKeyChecking=no root@${input:targetIP} \"date -s '$(date -u '+%Y-%m-%d %H:%M:%S')' > /dev/null 2>&1; cd /root/pmx; exec /bin/sh -l\"",
            "options": {
                "cwd": "${workspaceFolder}",
                "statusbar": {
                    "hide": false,
                    "label": "$(terminal) SSH",
                    "color": "#CCCCCC"
                }
            },
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "new", "focus": true, "close": true }
        },
        {
            // Rapatrie les fichiers SVG generes sur la carte
            "label": "ARM: Recup SVG",
            "type": "shell",
            "command": "sshpass -p pmx scp -o StrictHostKeyChecking=no root@${input:targetIP}:/root/pmx/*.svg ${workspaceFolder}/build-arm-release/bin/ && echo '🤖 Bip Positronik, Successful transmission, captain Cho !'",
            "options": {
                "cwd": "${workspaceFolder}",
                "statusbar": {
                    "hide": false,
                    "label": "$(file-media) Recup Log",
                    "color": "#DCDCAA"
                }
            },
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared", "close": true }
        },
        {
            // Ouvre le log SVG dans le navigateur
            "label": "SVG Log: Ouvrir",
            "type": "shell",
            "command": "setsid firefox ${workspaceFolder}/build-${input:buildPreset}/bin/index.html 2>/dev/null",
            "options": {
                "cwd": "${workspaceFolder}",
                "statusbar": {
                    "hide": false,
                    "label": "$(open-preview) SVG Log",
                    "color": "#DCDCAA"
                }
            },
            "problemMatcher": [],
            "presentation": { "reveal": "never" }
        },
        {
            // Generation de la documentation Doxygen
            "label": "Doxygen: Generer la doc",
            "type": "shell",
            "command": "doxygen && echo '🤖 Bip Positronik, Successful transmission, captain Cho !'",
            "options": {
                "cwd": "${workspaceFolder}",
                "statusbar": { "hide": true }
            },
            "group": "build",
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            // Genere la doc puis ouvre dans le navigateur
            "label": "Doxygen: Ouvrir la doc",
            "type": "shell",
            "command": "setsid firefox docs/html/index.html 2>/dev/null",
            "options": {
                "cwd": "${workspaceFolder}",
                "statusbar": { "hide": true }
            },
            "dependsOn": "Doxygen: Generer la doc",
            "problemMatcher": []
        },
        {
            // Clean build ARM release
            "label": "Clean: ARM Release",
            "type": "shell",
            "command": "cmake --build --preset arm-release --target clean && echo '🤖 Clean ARM Release OK'",
            "options": {
                "cwd": "${workspaceFolder}",
                "statusbar": { "hide": true }
            },
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared", "close": true }
        },
        {
            // Clean build ARM debug
            "label": "Clean: ARM Debug",
            "type": "shell",
            "command": "cmake --build --preset arm-debug --target clean && echo '🤖 Clean ARM Debug OK'",
            "options": {
                "cwd": "${workspaceFolder}",
                "statusbar": { "hide": true }
            },
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared", "close": true }
        },
        {
            // Clean build SIMU debug
            "label": "Clean: SIMU Debug",
            "type": "shell",
            "command": "cmake --build --preset simu-debug --target clean && echo '🤖 Clean SIMU Debug OK'",
            "options": {
                "cwd": "${workspaceFolder}",
                "statusbar": { "hide": true }
            },
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared", "close": true }
        },
        {
            // Clean build SIMU release
            "label": "Clean: SIMU Release",
            "type": "shell",
            "command": "cmake --build --preset simu-release --target clean && echo '🤖 Clean SIMU Release OK'",
            "options": {
                "cwd": "${workspaceFolder}",
                "statusbar": { "hide": true }
            },
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared", "close": true }
        },
        {
            // Clean tous les builds d'un coup
            "label": "Clean: ALL",
            "type": "shell",
            "command": "echo 'Clean all builds...'",
            "dependsOn": ["Clean: ARM Release", "Clean: ARM Debug", "Clean: SIMU Debug", "Clean: SIMU Release"],
            "options": {
                "cwd": "${workspaceFolder}",
                "statusbar": { "hide": true }
            },
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared", "close": true }
        }
    ]
}
