{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Doxygen: Generate docs",
            "type": "shell",
            "command": "doxygen",
            "args": ["Doxyfile"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Doxygen: Open docs",
            "type": "shell",
            "command": "xdg-open",
            "args": ["${workspaceFolder}/docs/html/index.html"],
            "dependsOn": "Doxygen: Generate docs",
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent"
            }
        }
    ]
}
